---
interface Line {
  content: string;
  href?: string;
}

const lines: Line[] = [
  { content: "Under Construction ..." },
  { content: "github.com/leehosanganson",          href: "https://github.com/leehosanganson" },
  { content: "linkedin.com/in/leehosanganson",     href: "https://linkedin.com/in/leehosanganson" },
  { content: "leehosanganson@gmail.com",           href: "mailto:leehosanganson@gmail.com" },
  { content: "" },
  { content: "https://life-in-the-uk-quiz.leehosanganson.dev/", href: "https://life-in-the-uk-quiz.leehosanganson.dev/" },
];
---

<div id="terminal">
  <div id="editor">
    <div id="gutter">
      {lines.map((_, i) => (
        <span class="ln" data-line={i + 1}>{i + 1}</span>
      ))}
    </div>
    <div id="buffer">
      {lines.map((line, i) => (
        <div
          class="line"
          data-line={i + 1}
          data-content={line.content || undefined}
          data-href={line.href || undefined}
        >
          <span class="text"></span>
        </div>
      ))}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    let row = 0;
    let col = 0;

    const lines   = Array.from(document.querySelectorAll<HTMLElement>('.line'));
    const lnSpans = Array.from(document.querySelectorAll<HTMLElement>('.ln'));

    // Build per-character spans for each line
    // charSpans[row] = array of <span class="ch"> elements
    const charSpans: HTMLElement[][] = [];

    lines.forEach((lineEl) => {
      const content = lineEl.dataset.content ?? '';
      const href    = lineEl.dataset.href;
      const textEl  = lineEl.querySelector<HTMLElement>('.text')!;

      const spans: HTMLElement[] = [];

      if (href) {
        // Wrap all chars in a single <a> tag
        const a = document.createElement('a');
        a.href   = href;
        a.target = '_blank';
        a.rel    = 'noopener';

        for (const char of content) {
          const ch = document.createElement('span');
          ch.className   = 'ch';
          ch.textContent = char;
          a.appendChild(ch);
          spans.push(ch);
        }
        textEl.appendChild(a);
      } else {
        for (const char of content) {
          const ch = document.createElement('span');
          ch.className   = 'ch';
          ch.textContent = char;
          textEl.appendChild(ch);
          spans.push(ch);
        }
      }

      charSpans.push(spans);
    });

    function lineLen(r: number): number {
      return charSpans[r]?.length ?? 0;
    }

    function clampCol(r: number, c: number): number {
      const len = lineLen(r);
      if (len === 0) return 0;
      return Math.max(0, Math.min(c, len - 1));
    }

    function render() {
      // Row highlight
      lines.forEach((l, i)   => l.classList.toggle('active', i === row));
      lnSpans.forEach((l, i) => l.classList.toggle('active', i === row));

      // Cursor character
      charSpans.forEach((rowSpans, r) => {
        rowSpans.forEach((ch, c) => {
          ch.classList.toggle('cur-char', r === row && c === col);
        });
      });
    }

    render();

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      switch (e.key) {
        case 'j':
        case 'ArrowDown':
          row = (row + 1) % lines.length;
          col = clampCol(row, col);
          render();
          e.preventDefault();
          break;
        case 'k':
        case 'ArrowUp':
          row = (row - 1 + lines.length) % lines.length;
          col = clampCol(row, col);
          render();
          e.preventDefault();
          break;
        case 'l':
        case 'ArrowRight':
          col = clampCol(row, col + 1);
          render();
          e.preventDefault();
          break;
        case 'h':
        case 'ArrowLeft':
          col = clampCol(row, col - 1);
          render();
          e.preventDefault();
          break;
        case '0':
          col = 0;
          render();
          e.preventDefault();
          break;
        case '$':
          col = Math.max(0, lineLen(row) - 1);
          render();
          e.preventDefault();
          break;
        case 'Enter':
          if (row > 0) {
            const a = lines[row]?.querySelector('a');
            if (a) a.click();
          }
          e.preventDefault();
          break;
      }
    });

    window.addEventListener('blur',  () => document.body.classList.add('paused'));
    window.addEventListener('focus', () => document.body.classList.remove('paused'));
  });
</script>
